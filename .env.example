# Contact form (app/api/contact/route.ts). Set these in Vercel → Project → Settings → Environment Variables.

# Required: Resend API key — https://resend.com/api-keys
RESEND_API_KEY=

# Optional: where submissions are delivered (defaults to the published contact address).
# CONTACT_TO_EMAIL=you@example.com

# Optional: verified Resend sender. Without a verified domain, leave unset to use
# onboarding@resend.dev (delivers only to the Resend account owner).
# CONTACT_FROM_EMAIL=Portfolio <contact@seifeldinali.com>
